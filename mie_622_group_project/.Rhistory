plot(model_1,1)
# create a dataframe
plot_data <- data.frame(
fitted = model_1$fitted.values,
residuals = model_1$residuals
)
# build the plot
ggplot(plot_data, aes(x = fitted, y = residuals)) +
geom_point(alpha = 0.5) +                # The points
geom_hline(yintercept = 0,               # The horizontal reference line
linetype = "dashed",
color = "black") +
geom_smooth(method = "loess",            # The trend line (similar to the red line in base plot)
formula = 'y ~ x',
color = "orange",
se = FALSE) +
theme_minimal() +
labs(title = "Residuals vs Fitted",
x = "Fitted Values",
y = "Residuals")
