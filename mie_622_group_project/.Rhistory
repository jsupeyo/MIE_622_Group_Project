# set up the libraries
library(tidyverse)
library(readxl)
library(here) # sets path to your folder directory
library(leaps) # for variable selection methods
library(ggplot2)
# load the data
pj_data <- read_xlsx(here("data", "project_data.xlsx")) # the data file is in a folder named 'data'
head(pj_data)
str(pj_data)
summary(pj_data)
pj_data <- na.omit(pj_data) # remove any missing values
# Factorize the categorical variables
# 'Target' is the only categorical variable
col <- c("Target")
pj_data [, col] <- lapply(pj_data[, col], factor)
str(pj_data) # confirm categorization of the column
# Let's take a look at the distribution of our variable of interest
pj_data |>
select(`Age at enrollment`)|>
ggplot(aes(x = `Age at enrollment`))+
geom_histogram(bins = 50, fill = "steelblue", color = "white")+
theme_minimal()+
labs( title = "Histogram of Age at Enrollment")+
geom_rug() # show the full breadth of the distribution
pj_data |>
ggplot(aes(x = `Age at enrollment`, y = .,))+
geom_histogram(bins = 50, fill = "steelblue", color = "white")+
theme_minimal()+
labs( title = "Histogram of Age at Enrollment")+
geom_rug() # show the full breadth of the distribution
pj_data |>
# Stack all columns EXCEPT 'Age at Enrollment'
pivot_longer(cols = -`Age at Enrollment`,
names_to = "Variable",
values_to = "Value") |>
ggplot(aes(x = Value, y = `Age at Enrollment`)) +
geom_point(alpha = 0.5) +  # Scatter plot for continuous variables
facet_wrap(~ Variable, scales = "free_x") +
theme_minimal() +
labs(title = "Age at Enrollment vs. All Other Variables")
pj_data |>
# Stack all columns EXCEPT 'Age at Enrollment'
pivot_longer(cols = -`Age at enrollment`,
names_to = "Variable",
values_to = "Value") |>
ggplot(aes(x = Value, y = `Age at enrollment`)) +
geom_point(alpha = 0.5) +  # Scatter plot for continuous variables
facet_wrap(~ Variable, scales = "free_x") +
theme_minimal() +
labs(title = "Age at Enrollment vs. All Other Variables")
library(tidyverse)
pj_data |>
pivot_longer(
cols = -`Age at Enrollment`,
names_to = "Variable",
values_to = "Value",
values_transform = list(Value = as.character) # This fixes the error
) |>
ggplot(aes(x = Value, y = `Age at Enrollment`)) +
geom_jitter(alpha = 0.4, width = 0.2) + # Jitter helps see overlapping points
facet_wrap(~ Variable, scales = "free_x") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) + # Rotates labels for readability
labs(title = "Age at Enrollment vs. All Variables")
library(tidyverse)
pj_data |>
pivot_longer(
cols = -`Age at enrollment`,
names_to = "Variable",
values_to = "Value",
values_transform = list(Value = as.character) # This fixes the error
) |>
ggplot(aes(x = Value, y = `Age at enrollment`)) +
geom_jitter(alpha = 0.4, width = 0.2) + # Jitter helps see overlapping points
facet_wrap(~ Variable, scales = "free_x") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) + # Rotates labels for readability
labs(title = "Age at Enrollment vs. All Variables")
# set up the libraries
library(tidyverse)
library(readxl)
library(here) # sets path to your folder directory
library(leaps) # for variable selection methods
library(ggplot2)
# load the data
pj_data <- read_xlsx(here("data", "project_data.xlsx")) # the data file is in a folder named 'data'
head(pj_data)
str(pj_data)
summary(pj_data)
pj_data <- na.omit(pj_data) # remove any missing values
# Factorize the categorical variables
# 'Target' is the only categorical variable
col <- c("Target")
pj_data [, col] <- lapply(pj_data[, col], factor)
str(pj_data) # confirm categorization of the column
# Let's take a look at the distribution of our variable of interest
pj_data |>
select(`Age at enrollment`)|>
ggplot(aes(x = `Age at enrollment`))+
geom_histogram(bins = 50, fill = "steelblue", color = "white")+
theme_minimal()+
labs( title = "Histogram of Age at Enrollment")+
geom_rug() # show the full breadth of the distribution
set.seed(123) # set a pseudorandom number generator
index <- sample(1:nrow(pj_data), 0.3 * nrow(pj_data)) # sample 30% of the data for testing
# split the data
training_data <- pj_data[-index, ]
testing_data <- pj_data[index, ]
# perfom forward stepwise selection
model.bestsubset <- regsubsets(`Age at enrollment` ~.,data = pj_data, nvmax = 36) # nvmax = 36 because we have 36 independent variables
summary(model.bestsubset)
library(caret)
set.seed(123)  # setting a seed for reproducibility of the random split
index <- createDataPartition(pj_data$`Age at enrollment`, p = 0.3, list = FALSE)
training_data <- pj_data[-index, ]
testing_data <- pj_data[index, ]
summary(training_data$`Age at enrollment`)
summary(training_data$`Age at enrollment`)
fitdata <- lm(pj_data~., data = training_data)
fitdata <- lm(~Age at enrollment`~., data = training_data)
fitdata <- lm(`Age at enrollment`~., data = training_data)
summary(fitdata)
pj_data |>
select(`Age at enrollment`)|>
ggplot(aes(x = `Age at enrollment`))+
geom_histogram(bins = 50, fill = "steelblue", color = "white")+
theme_minimal()+
labs( title = "Histogram of Age at Enrollment")+
geom_rug() # show the full breadth of the distribution
View(pj_data)
